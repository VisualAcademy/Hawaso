@page "/ApplicantsTransfers/ApplicantUpload"

@using Hawaso.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using VisualAcademy.Components.Pages.ApplicantsTransfers
@using VisualAcademy.Models
@using static Microsoft.AspNetCore.Components.Web.RenderMode

@inject ApplicantUploadService UploadService
@inject ApplicationDbContext DbContext
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject IWebHostEnvironment Environment
@inject NavigationManager NavigationManager

@* @attribute [Authorize] *@

@rendermode InteractiveServer

<h3>Applicant Data Upload</h3>

<div class="container mt-3">
    <p>
        Upload the template Excel file and preview it. If the data in the file matches an existing applicant,
        you will have the option to update their information.
    </p>

    <a href="/templates/ApplicantsTransfers/ApplicantsTransfers.xlsx" class="btn btn-secondary mb-3">
        Template Download
    </a>

    <EditForm EditContext="@editContext" OnValidSubmit="@FormSubmit" class="mb-3">
        <div class="form-group mb-2">
            <label for="txtFile">File</label>
            <Microsoft.AspNetCore.Components.Forms.InputFile OnChange="@HandleSelection" class="form-control" />
        </div>
    </EditForm>

    @if (applicantsPreview.Count > 0)
    {
        <ApplicantUploadPreview ApplicantTransfers="@applicantsPreview" />

        <button class="btn btn-success mt-2" @onclick="SaveApplicants">
            Save to Database
        </button>
    }

    @if (matchedApplicants.Count > 0)
    {
        <hr />
        <h3>Pending Applicant Data Updates</h3>

        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Field</th>
                    <th>Old Value</th>
                    <th>New Value</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var applicant in matchedApplicants)
                {
                    <tr>
                        <td>@applicant.ExistingApplicant.ID</td>
                        <td>First Name</td>
                        <td>@applicant.ExistingApplicant.FirstName</td>
                        <td>@applicant.NewApplicant.FirstName</td>
                    </tr>

                    @* 추가적인 필드를 위한 로우들은 여기에 구현 *@
                }
            </tbody>
        </table>
    }

    @if ((isAdministrator || isHR) && allApplicants.Count > 0)
    {
        <hr />
        <h3>Uploaded Data</h3>

        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Department</th>
                    <th>Employee Id</th>
                    <th>First Name</th>
                    <th>Middle Initial</th>
                    <th>Last Name</th>
                    <th>Date of Birth</th>
                    <th>SSN</th>
                    <th>Address 1</th>
                    <th>Address 2</th>
                    <th>City</th>
                    <th>State</th>
                    <th>Zip Code</th>
                    <th>Gender</th>
                    <th>Cell Phone</th>
                    <th>Primary Email</th>
                    <th>Employment Status</th>
                    <th>Date Seniority</th>
                    <th>Default Jobs (HR)</th>
                    <th>Employee Status</th>
                    <th>Tribal Nation</th>
                    <th>Gaming License Type</th>
                    <th>Date Re-Hired</th>
                    <th>Date Terminated</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var applicant in allApplicants)
                {
                    <tr>
                        <td>@applicant.ID</td>
                        <td>@applicant.DepartmentName</td>
                        <td>@applicant.EmployeeId</td>
                        <td>@applicant.FirstName</td>
                        <td>@applicant.MiddleName</td>
                        <td>@applicant.LastName</td>
                        <td>@applicant.DOB</td>
                        <td>@applicant.SSN</td>
                        <td>@applicant.Address</td>
                        <td>@applicant.Address2</td>
                        <td>@applicant.City</td>
                        <td>@applicant.State</td>
                        <td>@applicant.PostalCode</td>
                        <td>@applicant.Gender</td>
                        <td>@applicant.CellPhone</td>
                        <td>@applicant.PrimaryEmail</td>
                        <td>@applicant.EmploymentStatus</td>
                        <td>@applicant.DateSeniority</td>
                        <td>@applicant.DefaultJobsHR</td>
                        <td>@applicant.EmployeeStatus</td>
                        <td>@applicant.TribalNation</td>
                        <td>@applicant.GamingLicenseType</td>
                        <td>@applicant.DateRehired</td>
                        <td>@applicant.DateTerminated</td>
                        <td>
                            <button class="btn btn-danger" @onclick="(() => ShowConfirmation(applicant.ID))">
                                Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- 삭제 확인 모달 -->
<div class="modal" tabindex="-1" style="display:@(showConfirmation ? "block" : "none");">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Deletion</h5>
                <button type="button" class="btn-close" @onclick="HideConfirmation"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this applicant?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="HideConfirmation">
                    Close
                </button>
                <button type="button" class="btn btn-danger" @onclick="ConfirmDeletion">
                    Delete
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private const long MaxFileSize = 52_428_800; // 50MB

    private readonly EditContext editContext = new(new object());

    private List<ApplicantTransfer> applicantsPreview = new();
    private List<MatchedApplicantModel> matchedApplicants = new();
    private List<ApplicantTransfer> allApplicants = new();

    private bool isAdministrator = true;
    private bool isHR = true;

    private IBrowserFile? uploadedFile;

    private bool showConfirmation;
    private long deleteApplicantId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        // 실제 권한 체크를 사용할 경우 아래 코드 사용
        // if (user.Identity?.IsAuthenticated == true)
        // {
        //     var userName = user.Identity.Name;
        //
        //     if (!string.IsNullOrWhiteSpace(userName))
        //     {
        //         var appUser = await UserManager.FindByNameAsync(userName);
        //
        //         if (appUser is not null)
        //         {
        //             isAdministrator = await UserManager.IsInRoleAsync(appUser, "Administrators");
        //             isHR = await UserManager.IsInRoleAsync(appUser, "HR");
        //         }
        //     }
        // }

        allApplicants = await GetApplicantTransfers();
    }

    private async Task<List<ApplicantTransfer>> GetApplicantTransfers()
    {
        return await DbContext.ApplicantsTransfers
            .AsNoTracking()
            .ToListAsync();
    }

    private async Task HandleSelection(InputFileChangeEventArgs e)
    {
        uploadedFile = e.File;

        using var stream = uploadedFile.OpenReadStream(maxAllowedSize: MaxFileSize);

        applicantsPreview = await UploadService.ParseExcelAsync(stream);

        CompareAndPrepareMatchedApplicants();
    }

    private void FormSubmit()
    {
        // 필요한 경우 추가 로직 구현
    }

    private async Task SaveApplicants()
    {
        if (applicantsPreview.Count == 0)
        {
            await JSRuntime.InvokeVoidAsync("alert", "No applicant data to save.");
            return;
        }

        DbContext.ApplicantsTransfers.AddRange(applicantsPreview);
        await DbContext.SaveChangesAsync();

        if (uploadedFile is not null)
        {
            await SaveFileToServer(uploadedFile);
        }

        await JSRuntime.InvokeVoidAsync("alert", "Data and file successfully saved.");

        NavigationManager.NavigateTo("/ApplicantsTransfers/ApplicantUpload", forceLoad: true);
    }

    private void CompareAndPrepareMatchedApplicants()
    {
        matchedApplicants = new List<MatchedApplicantModel>();

        // TODO:
        // DbContext를 사용하여 기존 ApplicantTransfer 데이터와 applicantsPreview를 비교한 후,
        // 변경 가능성이 있는 항목을 matchedApplicants에 추가합니다.
        //
        // 예:
        // foreach (var newApplicant in applicantsPreview)
        // {
        //     var existingApplicant = allApplicants.FirstOrDefault(x =>
        //         x.EmployeeId == newApplicant.EmployeeId);
        //
        //     if (existingApplicant is not null)
        //     {
        //         matchedApplicants.Add(new MatchedApplicantModel(existingApplicant, newApplicant));
        //     }
        // }
    }

    private async Task UpdateApplicant(ApplicantTransfer existingApplicant, ApplicantTransfer newApplicant)
    {
        if (existingApplicant is null)
        {
            throw new ArgumentNullException(nameof(existingApplicant));
        }

        if (newApplicant is null)
        {
            throw new ArgumentNullException(nameof(newApplicant));
        }

        // TODO:
        // 변경 사항 적용 및 데이터베이스 업데이트 로직 구현
        //
        // existingApplicant.FirstName = newApplicant.FirstName;
        // existingApplicant.LastName = newApplicant.LastName;
        // ...

        await DbContext.SaveChangesAsync();
    }

    private static string NormalizeGender(string? gender)
    {
        return gender switch
        {
            "F" or "Female" => "Female",
            "M" or "Male" => "Male",
            "U" or "Other" => "Other",
            _ => gender ?? string.Empty
        };
    }

    private void ShowConfirmation(long applicantId)
    {
        deleteApplicantId = applicantId;
        showConfirmation = true;
    }

    private void HideConfirmation()
    {
        showConfirmation = false;
    }

    private async Task ConfirmDeletion()
    {
        var applicantToDelete = await DbContext.ApplicantsTransfers
            .FirstOrDefaultAsync(a => a.ID == deleteApplicantId);

        if (applicantToDelete is null)
        {
            showConfirmation = false;
            return;
        }

        DbContext.ApplicantsTransfers.Remove(applicantToDelete);
        await DbContext.SaveChangesAsync();

        var applicantInList = allApplicants.FirstOrDefault(a => a.ID == deleteApplicantId);

        if (applicantInList is not null)
        {
            allApplicants.Remove(applicantInList);
        }

        showConfirmation = false;
    }

    private async Task SaveFileToServer(IBrowserFile file)
    {
        var path = Path.Combine(Environment.WebRootPath, "files", "ApplicantTransfers");

        if (!Directory.Exists(path))
        {
            Directory.CreateDirectory(path);
        }

        var fileName = Path.GetFileNameWithoutExtension(file.Name);
        var fileExtension = Path.GetExtension(file.Name);

        var timestamp = DateTime.UtcNow.ToString("yyyyMMddHHmmssfff");
        var newFileName = $"{fileName}_{timestamp}{fileExtension}";
        var fullPath = Path.Combine(path, newFileName);

        await using var stream = file.OpenReadStream(maxAllowedSize: MaxFileSize);
        await using var fileStream = new FileStream(fullPath, FileMode.Create, FileAccess.Write);

        await stream.CopyToAsync(fileStream);
    }

    public sealed class MatchedApplicantModel
    {
        public MatchedApplicantModel(ApplicantTransfer existingApplicant, ApplicantTransfer newApplicant)
        {
            ExistingApplicant = existingApplicant ?? throw new ArgumentNullException(nameof(existingApplicant));
            NewApplicant = newApplicant ?? throw new ArgumentNullException(nameof(newApplicant));
        }

        public ApplicantTransfer ExistingApplicant { get; }

        public ApplicantTransfer NewApplicant { get; }
    }
}