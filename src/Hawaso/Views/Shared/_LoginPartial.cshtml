@using Hawaso.Data
@using Microsoft.AspNetCore.Identity

@* ASP.NET Core Identity 인증과 권한 *@
@inject SignInManager<ApplicationUser> SignInManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        @* 로그인한 최고 관리자(Administrators) 사용자에게만 표시 *@
        if (User.IsInRole("Administrators"))
        {
            <li class="nav-item">
                <a class="nav-link"
                   href="/Dashboard"
                   title="Dashboard">
                    Dashboard
                </a>
            </li>
        }

        <li class="nav-item">
            <a class="nav-link"
               asp-area="Identity"
               asp-page="/Account/Manage/Index"
               title="Manage">
                @User.Identity?.Name
            </a>
        </li>

        <li class="nav-item">
            <form class="form-inline"
                  asp-area="Identity"
                  asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                  method="post">
                <button type="submit"
                        class="nav-link btn btn-link">
                    Logout
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link"
               asp-area="Identity"
               asp-page="/Account/Register">
                Register
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link"
               asp-area="Identity"
               asp-page="/Account/Login">
                Login
            </a>
        </li>
    }
</ul>