@page
@model VisualAcademy.Pages.Cascading.Sublocations.DetailsModel

@{
    ViewData["Title"] = "Details";
    var sublocation = Model.Sublocation;
}

<h1>Details</h1>

@if (sublocation is null)
{
    <div class="alert alert-warning">
        Sublocation information is not available.
    </div>
}
else
{
    <div>
        <h4>Sublocation</h4>
        <hr />
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Sublocation.SublocationName)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(_ => sublocation.SublocationName)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Sublocation.Active)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(_ => sublocation.Active)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Sublocation.Location)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(_ => sublocation.Location)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Sublocation.Property)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(_ => sublocation.Property)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Sublocation.LocationRef)
            </dt>
            <dd class="col-sm-10">
                @(sublocation.LocationRef?.Id.ToString() ?? "")
            </dd>
        </dl>
    </div>

    <div>
        <a asp-page="./Edit" asp-route-id="@sublocation.Id">Edit</a> |
        <a asp-page="./Index">Back to List</a>
    </div>
}