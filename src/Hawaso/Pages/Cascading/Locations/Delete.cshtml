@page
@model VisualAcademy.Pages.Cascading.Locations.DeleteModel

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

@if (Model.Location is null)
{
    <div class="alert alert-warning">
        The location could not be found.
    </div>

    <a asp-page="./Index">Back to List</a>
}
else
{
    <h3>Are you sure you want to delete this?</h3>
    <div>
        <h4>Location</h4>
        <hr />
        <dl class="row">
            <dt class="col-sm-2">
                Name
            </dt>
            <dd class="col-sm-10">
                @Model.Location.Name
            </dd>

            <dt class="col-sm-2">
                Active
            </dt>
            <dd class="col-sm-10">
                @Model.Location.Active
            </dd>

            <dt class="col-sm-2">
                Property
            </dt>
            <dd class="col-sm-10">
                @Model.Location.Property
            </dd>

            <dt class="col-sm-2">
                Property Ref
            </dt>
            <dd class="col-sm-10">
                @(Model.Location.PropertyRef?.Id.ToString() ?? "")
            </dd>
        </dl>

        <form method="post">
            <input type="hidden" asp-for="Location.Id" />
            <input type="submit" value="Delete" class="btn btn-danger" /> |
            <a asp-page="./Index">Back to List</a>
        </form>
    </div>
}