@page "/Uploads/Create"

@attribute [Authorize(Roles = "Administrators")]

<h3>Create</h3>

<div class="row">
    <div class="col-md-12">
        <EditForm Model="Model" OnValidSubmit="FormSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group">
                <label for="txtName">Name</label>
                <InputText id="txtName"
                           class="form-control"
                           placeholder="Enter Name"
                           @bind-Value="Model.Name" />
                <ValidationMessage For="@(() => Model.Name)"
                                   class="form-text text-muted" />
            </div>

            <div class="form-group">
                <label for="txtTitle">Title</label>
                <InputText id="txtTitle"
                           class="form-control"
                           placeholder="Enter Title"
                           @bind-Value="Model.Title" />
                <ValidationMessage For="@(() => Model.Title)"
                                   class="form-text text-muted" />
            </div>

            <div class="form-group">
                <label for="txtContent">Content</label>
                <InputTextArea id="txtContent"
                               class="form-control"
                               placeholder="Enter Content"
                               rows="5"
                               @bind-Value="Model.Content" />
                <ValidationMessage For="@(() => Model.Content)"
                                   class="form-text text-muted" />
            </div>

            <div class="form-group">
                <label for="lstCategory">Parent</label>
                <InputSelect id="lstCategory"
                             class="form-control"
                             @bind-Value="ParentId">
                    <option value="">--Select Parent--</option>

                    @foreach (var parentId in parentIds)
                    {
                        <option value="@parentId">@parentId</option>
                    }
                </InputSelect>

                <ValidationMessage For="@(() => ParentId)"
                                   class="form-text text-muted" />
            </div>

            <div class="form-group">
                <label for="fileUpload">File</label>
                <BlazorInputFile.InputFile id="fileUpload"
                                           OnChange="HandleSelection" />
            </div>

            <div class="form-group">
                <button type="submit"
                        class="btn btn-primary">
                    Submit
                </button>

                <a href="/Uploads"
                   class="btn btn-secondary">
                    List
                </a>
            </div>
        </EditForm>
    </div>
</div>