@using Microsoft.AspNetCore.Components.Forms
@using System.Globalization
@using DocumentFormat.OpenXml.Packaging
@using DocumentFormat.OpenXml.Spreadsheet

<PageTitle>Excel 데이터 가져오기</PageTitle>

<h3>Excel 파일 업로드</h3>

<a href="/templates/Memos/MemosImport.xlsx" class="btn btn-secondary mb-3">Template Download</a>
<br />

<Microsoft.AspNetCore.Components.Forms.InputFile OnChange="HandleExcelUpload" accept=".xlsx" />

@if (memos.Count > 0)
{
    <h4>데이터 미리보기</h4>

    <table class="table">
        <thead>
            <tr>
                <th>이름</th>
                <th>이메일</th>
                <th>제목</th>
                <th>내용</th>
                <th>작성자</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var memo in memos)
            {
                <tr>
                    <td>@memo.Name</td>
                    <td>@memo.Email</td>
                    <td>@memo.Title</td>
                    <td>@memo.Content</td>
                    <td>@memo.CreatedBy</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Memo> memos = new();

    private async Task HandleExcelUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;

        await using var memoryStream = new MemoryStream();

        await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024)
            .CopyToAsync(memoryStream);

        memoryStream.Position = 0;

        using var document = SpreadsheetDocument.Open(memoryStream, false);

        var workbookPart = document.WorkbookPart;

        if (workbookPart?.Workbook is null)
        {
            memos = new List<Memo>();
            return;
        }

        var sheet = workbookPart.Workbook
            .Descendants<Sheet>()
            .FirstOrDefault();

        if (sheet?.Id?.Value is null)
        {
            memos = new List<Memo>();
            return;
        }

        var part = workbookPart.GetPartById(sheet.Id.Value);

        if (part is not WorksheetPart worksheetPart)
        {
            memos = new List<Memo>();
            return;
        }

        var sheetData = worksheetPart.Worksheet?
            .Elements<SheetData>()
            .FirstOrDefault();

        if (sheetData is null)
        {
            memos = new List<Memo>();
            return;
        }

        var loadedMemos = new List<Memo>();

        foreach (var row in sheetData.Descendants<Row>().Skip(1))
        {
            var cells = row.Descendants<Cell>().ToList();

            if (cells.Count < 5)
            {
                continue;
            }

            loadedMemos.Add(new Memo
            {
                Name = ReadCellValue(workbookPart, cells[0]),
                Email = ReadCellValue(workbookPart, cells[1]),
                Title = ReadCellValue(workbookPart, cells[2]),
                Content = ReadCellValue(workbookPart, cells[3]),
                CreatedBy = ReadCellValue(workbookPart, cells[4]),
                Created = DateTime.UtcNow
            });
        }

        memos = loadedMemos;
    }

    private static string ReadCellValue(WorkbookPart workbookPart, Cell cell)
    {
        var cellText = cell.InnerText;

        if (string.IsNullOrWhiteSpace(cellText))
        {
            return string.Empty;
        }

        if (cell.DataType?.Value == CellValues.SharedString)
        {
            if (!int.TryParse(cellText, NumberStyles.Integer, CultureInfo.InvariantCulture, out var sharedStringIndex))
            {
                return string.Empty;
            }

            var sharedStringTable = workbookPart.SharedStringTablePart?.SharedStringTable;

            if (sharedStringTable is null)
            {
                return string.Empty;
            }

            return sharedStringTable
                .ElementAtOrDefault(sharedStringIndex)?
                .InnerText ?? string.Empty;
        }

        return cellText;
    }

    private class Memo
    {
        public string Name { get; set; } = string.Empty;

        public string Email { get; set; } = string.Empty;

        public string Title { get; set; } = string.Empty;

        public string Content { get; set; } = string.Empty;

        public string CreatedBy { get; set; } = string.Empty;

        public DateTime Created { get; set; }
    }
}