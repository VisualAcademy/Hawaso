@page "/Categories"
@page "/Categories/Manage"

@attribute [Authorize(Roles = "Administrators")]

@using Hawaso.Pages.Categories.Components

<h3>Manage</h3>

<div class="mb-2">
    <input type="button"
           value="Create(Modal)"
           class="btn btn-primary"
           data-toggle="modal"
           data-target="#customerEditDialog"
           @onclick="btnCreate_Click" />
</div>

@if (isLoading)
{
    <div>
        <p>
            <MatProgressBar Indeterminate="true"></MatProgressBar>
        </p>
    </div>
}
else if (categories.Count == 0)
{
    <div class="alert alert-info">
        No categories found.
    </div>
}
else
{
    <table class="table table-bordered table-hover">
        <thead class="thead-light">
            <tr>
                <th>#</th>
                <th>Name</th>
                <th colspan="2">Admin</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in categories)
            {
                <tr>
                    <td>@category.CategoryId</td>
                    <td>@category.CategoryName</td>
                    <td>
                        <input type="button"
                               value="Edit(Modal)"
                               class="btn btn-primary"
                               data-toggle="modal"
                               data-target="#customerEditDialog"
                               @onclick="@(() => EditBy(category))" />
                    </td>
                    <td>
                        <input type="button"
                               value="Delete(Modal)"
                               class="btn btn-primary"
                               data-toggle="modal"
                               data-target="#customerDeleteDialog"
                               @onclick="@(() => DeleteBy(category))" />
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<DulPagerComponent Model="pager" PageIndexChanged="PageIndexChangedAsync"></DulPagerComponent>

<CategoryEditorForm @ref="categoryEditorForm"
                    Model="Category"
                    SaveOrUpdated="SaveOrUpdatedAsync"
                    ChangeCallback="SaveOrUpdatedAsync">
    <EditorFormTitle>@EditorFormTitle</EditorFormTitle>
</CategoryEditorForm>

<CategoryDeleteDialog @ref="categoryDeleteDialog"
                      OnClick="btnDelete_ClickAsync">
</CategoryDeleteDialog>